{
  "name": "libav-wasm",
  "version": "0.8.0",
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "types": "build/index.d.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev-web\" \"npm run worker-build-dev\"",
    "build-worker": "vite build --config vite-worker.config.ts",
    "dev-web": "vite --port 1234",
    "worker-build-dev": "nodemon -e ts --watch src/worker --exec \"npm run build-worker\"",
    "build": "vite build && npm run build-worker && npm run types",
    "types": "tsc",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^24.0.1",
    "concurrently": "^7.6.0",
    "nodemon": "^2.0.22",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "dependencies": {
    "@libav.js/types": "^6.8.8",
    "libav.js": "^6.8.8",
    "osra": "^0.2.0",
    "p-queue": "^7.3.0"
  }
}
